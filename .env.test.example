# ===========================================================
# YYC³ 智慧商家管理系统 - 测试账号模板
# ===========================================================
# 使用方法: 复制此文件为 .env.test 并填入实际值
#   cp .env.test.example .env.test
# ===========================================================

# ---------- 认证相关 ----------
NEXT_PUBLIC_APP_NAME="YYC³ 智慧商家管理系统"
NEXT_PUBLIC_API_BASE_URL="mock://localhost"
NEXT_PUBLIC_ENV="development"
NEXT_PUBLIC_SENTRY_DSN=""

# ---------- 测试账号 ----------
# 角色层级: admin > manager > staff
# 命名规则: yyc3_{role}_{序号}

# 管理员（全权限）
TEST_ADMIN_USERNAME="yyc3_admin"
TEST_ADMIN_PASSWORD="<请设置管理员密码>"

# 经理（管理权限）
TEST_MANAGER_USERNAME="yyc3_manager"
TEST_MANAGER_PASSWORD="<请设置经理密码>"

# 员工（基础权限）
TEST_STAFF_USERNAME="yyc3_staff"
TEST_STAFF_PASSWORD="<请设置员工密码>"

# ---------- 幽灵模式（开发调试，无需密码） ----------
GHOST_MODE_USER_ID="ghost-dev-user"
GHOST_MODE_USER_NAME="👻 幽灵开发者"

# ---------- API Mock配置 ----------
NEXT_PUBLIC_USE_MOCK="true"
NEXT_PUBLIC_MOCK_DELAY="500"

# ---------- 测试环境标识 ----------
NODE_ENV="test"
